# eBay — https://developer.ebay.com
# Option A: Auth'n'Auth (simpler — recommended for personal use)
#   Get token from User Tokens tab > Auth'n'Auth > Sign in to Production
EBAY_AUTH_TOKEN=
# Option B: OAuth (for Inventory API)
#   RuName redirect URL must be set to http://localhost:8888/callback
# EBAY_CLIENT_ID=
# EBAY_CLIENT_SECRET=
# EBAY_RUNAME=
# Set to "true" to use eBay sandbox for testing
# EBAY_SANDBOX=false
